TZ=UTC
# Paths in included compose files are resolved from ./compose, so use .. for repo root.
DOCKERDIR=/home/saad/docker-deployments/appdata/hermes/data/workspace/zavia-dev-env

# Domain and LAN routing
DOMAINNAME_1=zavia.lan
LOCAL_IPS=127.0.0.1/32,192.168.0.0/16,10.0.0.0/8

# Traefik ports
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080
MQTT_PORT=1883
MQTT_SECURE_PORT=8883

# PostgreSQL
POSTGRES_USER=zavia
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=zavia
PGADMIN_EMAIL=admin@zavia.lan
PGADMIN_PASSWORD=change_this_pgadmin_password

# Redis
REDIS_PASSWORD=change_this_redis_password

# Authentik
AUTHENTIK_SECRET_KEY=change_this_authentik_secret_key_at_least_50_chars
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=change_this_authentik_db_password
AUTHENTIK_EMAIL__HOST=mail.lan
AUTHENTIK_EMAIL__PORT=25
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=false
AUTHENTIK_EMAIL__FROM=authentik@zavia.lan

# InfluxDB
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=change_this_influx_password
INFLUXDB_INIT_ORG=Zavia
INFLUXDB_INIT_BUCKET=zavia
INFLUXDB_INIT_ADMIN_TOKEN=change_this_influx_admin_token

# UNS Builder source path (subtree location)
UNS_BUILDER_CONTEXT=../uns_builder
UNS_BUILDER_HOST_PORT=18000
UNS_MQTT_USERNAME=ThetaPhi
UNS_MQTT_PASSWORD=iEdge@Cv312DJ
UNS_MQTT_CLIENT_ID=uns_builder_dev
UNS_MQTT_TLS_ENABLED=false
UNS_MQTT_WILL_TOPIC=None
UNS_MQTT_WILL_PAYLOAD=None
